{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "manimforeducators",
  "version": "0.1.0",
  "identifier": "com.utsav.manimforeducators",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "backgroundColor":"#1F1F1F",
        "decorations": false,
        "width":1440,
        "height":900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin":[
      "binaries/manim-server"
    ],
    "icon": [
    ]
  }
}
